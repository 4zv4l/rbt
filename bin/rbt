        #     my $slot-size = $end - $start;
            
        #     my $done = ($start ..^ $end).grep({ $_ ∈ %infos<bitfield> }).elems;
        #     my $ratio = $slot-size ?? $done / $slot-size !! 0;
          
        #     given $ratio {
        #         when * == 1.0 { '█' }
        #         when * > 0.70 { '▓' }
        #         when * > 0.40 { '▒' }
