#!/usr/bin/env raku

use lib './lib';
use BT::Downloader;

unit sub MAIN(
          $file where *.IO.f,     #= .torrent file to download
    Str  :o(:$output-path) = '.', #= where to download the file(s)
    UInt :$pipeline = 15,         #= pipeline size
